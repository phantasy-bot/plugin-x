{
  "name": "@phantasy/plugin-x",
  "version": "2.0.0",
  "description": "Installable X/Twitter plugin surface for Phantasy",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "admin-ui-dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "ai",
    "agent",
    "plugin",
    "twitter",
    "x"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phantasy-bot/agent.git"
  },
  "bugs": {
    "url": "https://github.com/phantasy-bot/agent/issues"
  },
  "homepage": "https://github.com/phantasy-bot/agent#readme",
  "dependencies": {
    "@phantasy/agent": "^2.0.0"
  },
  "phantasy": {
    "displayName": "X (Twitter)",
    "icon": "𝕏",
    "category": "social",
    "tags": [
      "twitter",
      "x",
      "social-media",
      "posting"
    ],
    "workspace": "business",
    "extensionKind": "integration",
    "permissions": [
      "internet"
    ],
    "platforms": [
      "node"
    ],
    "productionReady": true,
    "adminSurface": {
      "tabId": "x",
      "label": "X",
      "section": "business",
      "workspace": "business",
      "kind": "native",
      "entry": "/admin-ui/index.js",
      "assetRoot": "admin-ui-dist",
      "keywords": [
        "twitter",
        "x",
        "social",
        "posting"
      ],
      "aliases": [
        "twitter",
        "x"
      ],
      "dashboardIcon": "chatRoundLike"
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "autonomousPosting": {
          "type": "boolean",
          "default": false
        },
        "postingIntervalMinutes": {
          "type": "number",
          "default": 60
        },
        "maxPostsPerDay": {
          "type": "number",
          "default": 8
        },
        "activeHours": {
          "type": "string",
          "default": "9-21"
        },
        "requireApproval": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
