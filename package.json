{
  "name": "@phantasy/plugin-x",
  "version": "2.0.1",
  "private": false,
  "description": "Installable X/Twitter plugin surface for Phantasy",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "admin-ui-dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "phantasy.plugin.json"
  ],
  "sideEffects": false,
  "keywords": [
    "twitter",
    "x",
    "social-media",
    "posting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phantasy-bot/plugin-x"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/phantasy-bot/plugin-x",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@phantasy/agent": "^2.0.1"
  },
  "dependencies": {
    "twitter-api-v2": "1.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "phantasy": {
    "displayName": "X (Twitter)",
    "icon": "𝕏",
    "category": "social",
    "tags": [
      "twitter",
      "x",
      "social-media",
      "posting"
    ],
    "workspace": "business",
    "extensionKind": "integration",
    "permissions": [
      "internet"
    ],
    "platforms": [
      "node"
    ],
    "productionReady": true,
    "adminSurface": {
      "tabId": "x",
      "label": "X",
      "section": "business",
      "workspace": "business",
      "kind": "native",
      "entry": "/admin-ui/index.js",
      "assetRoot": "admin-ui-dist",
      "keywords": [
        "twitter",
        "x",
        "social",
        "posting"
      ],
      "aliases": [
        "twitter",
        "x"
      ],
      "dashboardIcon": "twitter"
    },
    "configSchema": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "autonomousPosting": {
          "type": "boolean",
          "default": false
        },
        "postingIntervalMinutes": {
          "type": "number",
          "default": 60
        },
        "maxPostsPerDay": {
          "type": "number",
          "default": 8
        },
        "activeHours": {
          "type": "string",
          "default": "9-21"
        },
        "requireApproval": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
